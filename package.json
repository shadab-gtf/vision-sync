{
  "name": "vision-sync",
  "version": "0.1.0",
  "description": "Deterministic frontend API synchronization engine for React and Next.js.",
  "type": "module",
  "bin": {
    "vision-sync": "./dist/cli/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "examples",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "dependencies": {
    "boxen": "^8.0.1",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "ora": "^8.1.1",
    "prompts": "^2.4.2",
    "ts-morph": "^22.0.0",
    "typescript": "^5.5.4",
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.15",
    "@types/prompts": "^2.4.9"
  },
  "keywords": [
    "openapi",
    "react",
    "nextjs",
    "typescript",
    "ast",
    "codegen"
  ],
  "license": "MIT"
}
